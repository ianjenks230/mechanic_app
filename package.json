{
  "name": "mobile-mechanix",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.8.2",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "web",
    "server"
  ],
  "scripts": {
    "dev:web": "npm --workspace web run dev",
    "dev:server": "npm --workspace server run dev",
    "build:web": "npm --workspace web run build",
    "build": "npm run build:web && node scripts/copy-dist.mjs",
    "start": "npm --workspace server run start"
  }
}
